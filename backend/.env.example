# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
DB_NAME=lluvia_admin
CORS_ORIGINS=*

# ── LLM providers ─────────────────────────────────────────────────────────────
# Primary: used by E1 console for reliable tool-calling (gpt-4o-mini)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Fast/cheap: used for simple generation tasks
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant
# Override console model (default: llama-3.3-70b-versatile when using Groq)
# GROQ_CONSOLE_MODEL=llama-3.3-70b-versatile

# Optional: OpenRouter for Claude/Gemini access
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3-haiku
# OPENROUTER_MODEL_HIGH=anthropic/claude-3-5-sonnet

# Force E1 console to use a specific provider: openai | groq | openrouter
# CONSOLE_LLM_PROVIDER=openai

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe#2024
MASTER_KEY=change-me-in-production

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_POLLING=0
ADMIN_TELEGRAM_CHAT_IDS=

# ── WhatsApp / Instagram (Meta Cloud API) ────────────────────────────────────
VERIFY_TOKEN=changeme
WHATSAPP_TOKEN=
PHONE_ID=
INSTAGRAM_TOKEN=
IG_ID=

# ── GitHub integration ────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_USER=
GITHUB_BACKUP_REPO=

# ── PayPal ────────────────────────────────────────────────────────────────────
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=

# ── VPS / infra paths ─────────────────────────────────────────────────────────
LLUVIA_HOME=/opt/lluvia
LLUVIA_BASE_DOMAIN=yourdomain.com
LLUVIA_DRY_RUN=0
LLUVIA_SOURCE=/opt/lluvia
LLUVIA_TEMPLATES=/opt/lluvia/scripts/templates
